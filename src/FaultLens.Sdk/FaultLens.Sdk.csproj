<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>netstandard2.1</TargetFramework>
		<LangVersion>8.0</LangVersion>
		<Nullable>enable</Nullable>
		<ImplicitUsings>disable</ImplicitUsings>

		<!-- Package Identity -->
		<PackageId>FaultLens.Sdk</PackageId>
		<Version>0.1.7</Version>
		<Authors>FaultLens</Authors>
		<Company>FaultLens</Company>
		<IsPackable>true</IsPackable>

		<!-- Package Metadata -->
		<Description>FaultLens .NET SDK for non-blocking production error capture, breadcrumbs, and request-scoped diagnostics.</Description>
		<PackageTags>faultlens;errors;observability;monitoring</PackageTags>
		<PackageProjectUrl>https://faultlens.in/docs</PackageProjectUrl>
		<RepositoryUrl>https://github.com/FaultLensHQ/faultlens-sdk-dotnet</RepositoryUrl>
		<RepositoryType>git</RepositoryType>
		<PublishRepositoryUrl>true</PublishRepositoryUrl>
		<PackageLicenseExpression>MIT</PackageLicenseExpression>
		<PackageReadmeFile>README.md</PackageReadmeFile>

		<!-- Build Settings -->
		<GeneratePackageOnBuild>false</GeneratePackageOnBuild>
		<Nullable>disable</Nullable>

		<!-- Deterministic & Safe -->
		<TreatWarningsAsErrors>true</TreatWarningsAsErrors>
	</PropertyGroup>

	<ItemGroup>
		<None Include="..\..\README.md" Pack="true" PackagePath="\" Visible="false" />
	</ItemGroup>

	<ItemGroup>
	  <PackageReference Include="System.Diagnostics.DiagnosticSource" Version="10.0.0" />
	  <PackageReference Include="System.Text.Json" Version="10.0.1" />
	</ItemGroup>

	<ItemGroup>
		<AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleTo">
			<_Parameter1>FaultLens.Sdk.Tests</_Parameter1>
		</AssemblyAttribute>
	</ItemGroup>

</Project>
