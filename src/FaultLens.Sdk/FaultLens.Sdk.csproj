<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>netstandard2.1</TargetFramework>
		<LangVersion>8.0</LangVersion>
		<Nullable>enable</Nullable>

		<!-- NuGet metadata -->
		<PackageId>FaultLens.Sdk</PackageId>
		<Version>1.0.0</Version>
		<Authors>FaultLens</Authors>
		<Company>FaultLens</Company>
		<Description>Official .NET SDK for FaultLens error monitoring</Description>
		<PackageTags>faultlens;error-monitoring;logging;observability</PackageTags>
		<PackageLicenseExpression>MIT</PackageLicenseExpression>
		<RepositoryUrl>https://github.com/faultlens/faultlens-sdk-dotnet</RepositoryUrl>
		<RepositoryType>git</RepositoryType>

		<GeneratePackageOnBuild>false</GeneratePackageOnBuild>
		<IncludeSymbols>true</IncludeSymbols>
		<SymbolPackageFormat>snupkg</SymbolPackageFormat>
	</PropertyGroup>

	<ItemGroup>
	  <PackageReference Include="Microsoft.Extensions.Http" Version="10.0.1" />
	  <PackageReference Include="System.Text.Json" Version="10.0.1" />
	</ItemGroup>

</Project>
