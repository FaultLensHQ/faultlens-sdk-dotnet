<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>netstandard2.1</TargetFramework>
		<LangVersion>8.0</LangVersion>
		<Nullable>enable</Nullable>
		<ImplicitUsings>disable</ImplicitUsings>

		<!-- Package Identity -->
		<PackageId>FaultLens.SDK</PackageId>
		<Version>1.0.0</Version>
		<Authors>FaultLens</Authors>
		<Company>FaultLens</Company>
		<IsPackable>true</IsPackable>
		<PackageReleaseNotes>
			* Initial stable release of the official FaultLens .NET SDK.
			* Includes error capture, environment and release context, service name/version context, account and user identity context, anonymous identity support, correlation ID support, breadcrumbs, tags, request context, and safe contextual diagnostics for FaultLens.
			* ASP.NET Core automatic middleware/header capture is not included in this release; use the request scope/manual capture APIs for request context.
        </PackageReleaseNotes>

		<!-- Package Metadata -->
		<Description>Official FaultLens .NET SDK for capturing and sending application errors and diagnostics to FaultLens.</Description>
		<PackageTags>faultlens;monitoring;observability;errors;diagnostics;dotnet</PackageTags>
		<PackageProjectUrl>https://faultlens.in</PackageProjectUrl>
		<RepositoryUrl>https://github.com/FaultLensHQ/faultlens-sdk-dotnet</RepositoryUrl>
		<RepositoryType>git</RepositoryType>
		<PublishRepositoryUrl>true</PublishRepositoryUrl>
		<PackageLicenseExpression>MIT</PackageLicenseExpression>
		<PackageReadmeFile>README.md</PackageReadmeFile>

		<!-- Build Settings -->
		<GeneratePackageOnBuild>false</GeneratePackageOnBuild>
		<IncludeSymbols>true</IncludeSymbols>
		<SymbolPackageFormat>snupkg</SymbolPackageFormat>
		<Nullable>disable</Nullable>

		<!-- Deterministic & Safe -->
		<TreatWarningsAsErrors>true</TreatWarningsAsErrors>
	</PropertyGroup>

	<ItemGroup>
		<None Include="..\..\README.md" Pack="true" PackagePath="\" Visible="false" />
	</ItemGroup>

	<ItemGroup>
	  <PackageReference Include="System.Diagnostics.DiagnosticSource" Version="10.0.0" />
	  <PackageReference Include="System.Text.Json" Version="10.0.1" />
	</ItemGroup>

	<ItemGroup>
		<AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleTo">
			<_Parameter1>FaultLens.Sdk.Tests</_Parameter1>
		</AssemblyAttribute>
	</ItemGroup>

</Project>
