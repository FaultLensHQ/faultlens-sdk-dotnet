<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>netstandard2.1</TargetFramework>
		<LangVersion>8.0</LangVersion>
		<Nullable>enable</Nullable>

		<!-- Package Identity -->
		<PackageId>FaultLens.Sdk</PackageId>
		<Version>0.1.2</Version>
		<Authors>FaultLens</Authors>
		<Company>FaultLens</Company>

		<!-- Package Metadata -->
		<Description>FaultLens .NET SDK for error tracking and observability.</Description>
		<PackageTags>faultlens;errors;observability;monitoring</PackageTags>
		<RepositoryUrl>https://github.com/FaultLensHQ/faultlens-sdk-dotnet</RepositoryUrl>
		<RepositoryType>git</RepositoryType>
		<PackageLicenseExpression>MIT</PackageLicenseExpression>

		<!-- Build Settings -->
		<GeneratePackageOnBuild>false</GeneratePackageOnBuild>
		<Nullable>disable</Nullable>
		<ImplicitUsings>disable</ImplicitUsings>

		<!-- Deterministic & Safe -->
		<TreatWarningsAsErrors>true</TreatWarningsAsErrors>
	</PropertyGroup>

	<ItemGroup>
	  <PackageReference Include="Microsoft.Extensions.Http" Version="10.0.1" />
	  <PackageReference Include="System.Text.Json" Version="10.0.1" />
	</ItemGroup>

</Project>
